datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OWNER
  CUSTOMER
  SUPPORT
  PARTNER
  SUB_USER
}

enum BillboardType {
  STATIC
  DIGITAL
  LED
}

enum BillboardStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum MediaType {
  IMAGE
  VIDEO
  PANORAMA
}

enum CampaignStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PENDING_PAYMENT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  OFFERED
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  PENDING
  SIGNED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  RAZORPAY
  PAYPAL
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum AssetType {
  LOGO
  IMAGE
  VIDEO
  SHAPE
  ICON
  STICKER
  FONT
}

enum DesignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ARCHIVED
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?       @unique
  isEmailVerified  Boolean       @default(false)
  isPhoneVerified  Boolean       @default(false)
  mfaSecret        String?
  mfaEnabled       Boolean       @default(false)
  role             UserRole      @default(CUSTOMER)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  profile          Profile?
  brandAssets      BrandAsset[]
  billboards       Billboard[]   @relation("OwnerBillboards")
  campaigns        Campaign[]
  bookings         Booking[]
  referredBy       Referral[]    @relation("ReferrerRelation")
  referee          Referral[]    @relation("RefereeRelation")
  sentMessages     Message[]     @relation("SenderRelation")
  receivedMessages Message[]     @relation("ReceiverRelation")
  ticketsCreated   Ticket[]      @relation("TicketCreator")
  ticketsAssigned  Ticket[]      @relation("TicketAgent")
  reviews          Review[]
  auditLogs        AuditLog[]
  workspaces       TeamMember[]
  designs          Design[]
  comments         Comment[]
}

model Profile {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName            String?
  businessTaxId           String?
  address                 String?
  billingDetails          Json?
  logoUrl                 String?
  notificationPreferences Json?
  privacySettings         Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model BrandAsset {
  id           String     @id @default(uuid())
  customerId   String
  customer     User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  folderId     String?
  folder       Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name         String
  logoUrl      String?
  assetUrl     String
  colorPalette Json?
  typography   Json?
  type         AssetType  @default(IMAGE)
  size         Int        @default(0)
  mimeType     String     @default("image/png")
  width        Int?
  height       Int?
  tags         String[]
  version      Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Workspace {
  id          String       @id @default(uuid())
  name        String
  logoUrl     String?
  members     TeamMember[]
  folders     Folder[]
  designs     Design[]
  brandAssets BrandAsset[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
}

model Folder {
  id          String       @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Folder?      @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  subFolders  Folder[]     @relation("SubFolders")
  assets      BrandAsset[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Design {
  id          String          @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  width       Int
  height      Int
  canvasJson  String          @db.Text
  status      DesignStatus    @default(DRAFT)
  isTemplate  Boolean         @default(false)
  categoryId  String?
  category    TemplateCategory? @relation(fields: [categoryId], references: [id])
  versions    DesignVersion[]
  comments    Comment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model DesignVersion {
  id         String   @id @default(uuid())
  designId   String
  design     Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  canvasJson String   @db.Text
  version    Int
  createdByName String
  createdAt  DateTime @default(now())
}

model TemplateCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  designs   Design[]
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  designId  String
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  x         Float
  y         Float
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String      @id @default(uuid())
  name       String      @unique
  slug       String      @unique
  billboards Billboard[]
}

model Billboard {
  id                  String                @id @default(uuid())
  ownerId             String
  owner               User                  @relation("OwnerBillboards", fields: [ownerId], references: [id], onDelete: Cascade)
  categoryId          String
  category            Category              @relation(fields: [categoryId], references: [id])
  name                String
  type                BillboardType         @default(STATIC)
  description         String
  width               Float
  height              Float
  address             String
  city                String                @default("")
  state               String                @default("")
  country             String                @default("")
  postalCode          String                @default("")
  latitude            Float
  longitude           Float
  basePrice           Decimal               @db.Decimal(10, 2)
  minimumBookingDays  Int                   @default(1)
  isAvailable         Boolean               @default(true)
  rating              Float                 @default(0.0)
  reviewCount         Int                   @default(0)
  views               Int                   @default(0)
  status              BillboardStatus       @default(PENDING)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  media               BillboardMedia[]
  bookings            Booking[]
  reviews             Review[]
  maintenance         MaintenanceSchedule[]
  availability        BillboardAvailability[]
  pricing             BillboardPricing[]
}

model BillboardAvailability {
  id            String    @id @default(uuid())
  billboardId   String
  billboard     Billboard @relation(fields: [billboardId], references: [id], onDelete: Cascade)
  date          DateTime
  isAvailable   Boolean   @default(true)
  blockedReason String?
}

model BillboardPricing {
  id              String    @id @default(uuid())
  billboardId     String
  billboard       Billboard @relation(fields: [billboardId], references: [id], onDelete: Cascade)
  startDate       DateTime
  endDate         DateTime
  priceMultiplier Decimal   @db.Decimal(5, 2)
  peakSeason      Boolean   @default(false)
  weekendPricing  Boolean   @default(false)
}

model BillboardMedia {
  id           String    @id @default(uuid())
  billboardId  String
  billboard    Billboard @relation(fields: [billboardId], references: [id], onDelete: Cascade)
  fileUrl      String
  thumbnailUrl String?
  fileType     MediaType @default(IMAGE)
  displayOrder Int       @default(0)
}

model Campaign {
  id         String         @id @default(uuid())
  customerId String
  customer   User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  budget     Decimal        @db.Decimal(12, 2)
  status     CampaignStatus @default(DRAFT)
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  bookings   Booking[]
}

model Booking {
  id          String        @id @default(uuid())
  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billboardId String
  billboard   Billboard     @relation(fields: [billboardId], references: [id])
  startDate   DateTime
  endDate     DateTime
  totalAmount Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  quotation   Quotation?
  payments    Payment[]
}

model Quotation {
  id             String          @id @default(uuid())
  bookingId      String          @unique
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  initialPrice   Decimal         @db.Decimal(10, 2)
  taxAmount      Decimal         @db.Decimal(10, 2)
  discountAmount Decimal         @db.Decimal(10, 2)
  finalPrice     Decimal         @db.Decimal(10, 2)
  status         QuotationStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  contract       Contract?
}

model Contract {
  id                String         @id @default(uuid())
  quotationId       String         @unique
  quotation         Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  documentUrl       String
  signatureCustomer String?
  signatureOwner    String?
  status            ContractStatus @default(PENDING)
  signedAt          DateTime?
  createdAt         DateTime       @default(now())
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  couponId          String?
  coupon            Coupon?       @relation(fields: [couponId], references: [id])
  gatewayIntentId   String        @unique
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod
  installmentNumber Int           @default(1)
  createdAt         DateTime      @default(now())
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   DiscountType @default(PERCENTAGE)
  discountValue  Decimal      @db.Decimal(10, 2)
  maxUsage       Int          @default(100)
  currentUsage   Int          @default(0)
  minOrderAmount Decimal      @db.Decimal(10, 2)
  expiryDate     DateTime
  active         Boolean      @default(true)
  stackable      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  payments       Payment[]
}

model Referral {
  id               String   @id @default(uuid())
  referrerId       String
  referrer         User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  refereeId        String
  referee          User     @relation("RefereeRelation", fields: [refereeId], references: [id])
  referralCode     String
  commissionEarned Decimal  @db.Decimal(10, 2) @default(0.00)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  sender     User      @relation("SenderRelation", fields: [senderId], references: [id])
  receiverId String
  receiver   User      @relation("ReceiverRelation", fields: [receiverId], references: [id])
  content    String
  mediaUrl   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Ticket {
  id          String         @id @default(uuid())
  creatorId   String
  creator     User           @relation("TicketCreator", fields: [creatorId], references: [id])
  agentId     String?
  agent       User?          @relation("TicketAgent", fields: [agentId], references: [id])
  subject     String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Review {
  id          String    @id @default(uuid())
  customerId  String
  customer    User      @relation(fields: [customerId], references: [id])
  billboardId String
  billboard   Billboard @relation(fields: [billboardId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String
  createdAt   DateTime  @default(now())
}

model MaintenanceSchedule {
  id          String    @id @default(uuid())
  billboardId String
  billboard   Billboard @relation(fields: [billboardId], references: [id], onDelete: Cascade)
  description String
  startDate   DateTime
  endDate     DateTime
  status      String    @default("SCHEDULED")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  ipAddress String?
  userAgent String?
  payload   Json?
  createdAt DateTime @default(now())
}
